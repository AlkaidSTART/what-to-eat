// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
}

// 用户表
model User {
  id        String     @id @default(cuid())
  username  String     @unique
  password  String     
  roulettes Roulette[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

// 转盘表（菜单组）
model Roulette {
  id          String         @id @default(cuid())
  name        String         
  type        RouletteType   @default(NONE) 
  isDefault   Boolean        @default(false) 
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       RouletteItem[] 
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

// 转盘内置选项表（具体餐品）
model RouletteItem {
  id               String   @id @default(cuid())
  name             String   
  fixedProbability Float?   
  rouletteId       String
  roulette         Roulette @relation(fields: [rouletteId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// 时间段枚举
enum RouletteType {
  BREAKFAST  
  LUNCH      
  AFTERNOON  
  DINNER     
  NIGHT      
  NONE       
}